# ── Provider selection ─────────────────────────────────────────────────────────
# Options: anthropic | grok | groq
PROVIDER=anthropic

# ── API keys (only the key for your chosen provider is required) ───────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # https://console.anthropic.com
XAI_API_KEY=your_xai_api_key_here               # https://console.x.ai      (for xAI Grok)
GROQ_API_KEY=your_groq_api_key_here             # https://console.groq.com  (for Groq)

# ── Model override (optional) ──────────────────────────────────────────────────
# Defaults: anthropic→claude-opus-4-6  grok→grok-3  groq→llama-3.3-70b-versatile
# MODEL=llama-3.1-8b-instant

# ── Other settings ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_token_here
DATABASE_URL=sqlite:///./sentinel.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
